# =============================================================================
# Supabase
# Get these from: https://supabase.com → your project → Settings → API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role key — used ONLY on the server (in API routes) for admin actions.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Admin Dashboard
# Change this to a strong password before deploying!
# =============================================================================
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string

# =============================================================================
# WhatsApp COD Order-Confirmation SaaS
# =============================================================================

# Postgres connection string for Prisma.
# Example (Supabase): postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_cod

# --- Twilio (account-level credentials) -------------------------------------
# Console → Account → API keys & tokens.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# --- Public base URL --------------------------------------------------------
# Used to reconstruct the URL Twilio signed when validating inbound
# webhooks behind a proxy / serverless host. No trailing slash.
# Example: https://app.example.com
PUBLIC_BASE_URL=https://app.example.com

# --- Shopify App (OAuth install flow) ---------------------------------------
# Shopify Partners → Apps → Your App → API credentials.
SHOPIFY_API_KEY=your-shopify-app-client-id
SHOPIFY_API_SECRET=your-shopify-app-client-secret
# Comma-separated. Add scopes here as the app needs them.
SHOPIFY_SCOPES=read_orders,write_orders
# Secret used to sign the OAuth `state` cookie (CSRF). Any long random string.
SHOPIFY_STATE_SECRET=change-this-to-a-long-random-string

# --- Cron ------------------------------------------------------------------
# Bearer token required by /api/cron/expire-pending. Set the same value in
# the Vercel Cron Authorization header.
CRON_SECRET=change-this-to-a-long-random-string
# Hours a PENDING_CONFIRMATION order can sit before being marked EXPIRED.
PENDING_EXPIRY_HOURS=24

# -----------------------------------------------------------------------------
# Per-merchant credentials live in the database (`Merchant` model), not here:
#   - shopifyDomain          e.g. "my-store.myshopify.com"
#   - shopifyAccessToken     captured via the OAuth callback
#   - shopifyWebhookSecret   set to SHOPIFY_API_SECRET on install (Shopify
#                            signs webhooks with the app secret)
#   - whatsappFromNumber     Twilio WhatsApp sender in E.164, e.g. "+14155238886"
#   - whatsappTemplateSid    Twilio Content SID of the approved template with
#                            "Confirm" / "Cancel" quick-reply buttons
# -----------------------------------------------------------------------------
